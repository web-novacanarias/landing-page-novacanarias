---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "Consultoría estratégica especializada en Canarias. Soluciones para empresas y profesionales.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:image" content="/imagen-share.jpg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href="https://canariasnova.com" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://canariasnova.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/nova-logo.avif" />
  </head>
  <body class="bg-[#00236a] text-white font-sans antialiased overflow-x-hidden">
    <nav class="fixed top-4 inset-x-0 z-[100] flex justify-center px-4">
      <div
        class="w-full max-w-6xl bg-blue-900/20 backdrop-blur-xl border border-white/20 rounded-2xl md:rounded-full px-6 py-3 flex items-center justify-between shadow-2xl relative z-20"
      >
        <div class="flex items-center">
          <a href="/">
            <img
              src="/nova-logo.avif"
              alt="Nova Consulting Logo"
              class="h-9 md:h-10 w-auto object-contain"
              loading="eager"
            />
          </a>
        </div>

        <div
          class="hidden md:flex items-center gap-8 text-xs font-bold uppercase tracking-widest text-blue-100"
        >
          <a href="/#servicios" class="hover:text-white transition">Servicios</a
          >
          <a href="/#nosotros" class="hover:text-white transition">Nosotros</a>
          <a href="/#sectores" class="hover:text-white transition">Sectores</a>
          <a href="/#equipo" class="hover:text-white transition">Equipo</a>
        </div>

        <div class="flex items-center gap-4">
          <a
            href="/#contacto"
            class="hidden md:block bg-white text-[#00236a] px-5 py-2 rounded-full text-xs font-black uppercase hover:scale-105 transition shadow-lg"
          >
            Contacto
          </a>
          <button
            id="menu-toggle"
            class="md:hidden text-white p-1 outline-none"
          >
            <svg
              id="menu-icon"
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6 transition-transform duration-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16m-7 6h7"></path>
            </svg>
          </button>
        </div>
      </div>

      <div
        id="mobile-menu"
        class="absolute top-full left-4 right-4 mt-2 bg-blue-900/40 backdrop-blur-2xl border border-white/20 rounded-3xl p-8 flex flex-col gap-5 text-sm font-bold uppercase tracking-widest shadow-[0_20px_50px_rgba(0,0,0,0.3)] origin-top transition-all duration-300 scale-y-0 opacity-0 pointer-events-none md:hidden z-10"
      >
        <a
          href="/#servicios"
          class="mobile-link hover:text-blue-400 border-b border-white/10 pb-3 transition-colors"
          >Servicios</a
        >
        <a
          href="/#nosotros"
          class="mobile-link hover:text-blue-400 border-b border-white/10 pb-3 transition-colors"
          >Nosotros</a
        >
        <a
          href="/#sectores"
          class="mobile-link hover:text-blue-400 border-b border-white/10 pb-3 transition-colors"
          >Sectores</a
        >
        <a
          href="/#equipo"
          class="mobile-link hover:text-blue-400 border-b border-white/10 pb-3 transition-colors"
          >Equipo</a
        >
        <a
          href="/#contacto"
          class="mobile-link text-center bg-white text-[#00236a] rounded-xl py-4 font-black shadow-lg active:scale-95 transition-transform"
          >Contacto</a
        >
      </div>
    </nav>

    <main class="pt-24 md:pt-32">
      <slot />
    </main>

    <footer class="bg-[#001a4d] pt-20 pb-10 px-6 border-t border-white/5 mt-20">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
          <div class="col-span-1 space-y-8 text-center md:text-left">
            <div class="space-y-4">
              <img
                src="/nova-logo.avif"
                alt="Nova Logo"
                class="h-10 w-auto mx-auto md:mx-0 opacity-80"
              />
              <p class="text-blue-100/50 text-sm italic leading-relaxed">
                Soluciones estratégicas y compromiso profesional en Canarias.
              </p>
            </div>

            <div class="space-y-2">
              <p
                class="text-white text-[10px] font-black uppercase tracking-widest opacity-70"
              >
                Horario de atención
              </p>
              <div class="flex flex-col text-sm">
                <span class="text-blue-100/80">Lunes a Viernes</span>
                <span class="text-blue-400 font-bold text-lg"
                  >09:00 — 17:00</span
                >
              </div>
            </div>
          </div>

          <div class="text-center md:text-left">
            <h4
              class="text-white font-black uppercase text-xs tracking-widest mb-6"
            >
              Navegación
            </h4>
            <ul class="space-y-4 text-sm font-medium text-blue-100/60">
              <li>
                <a href="/#servicios" class="hover:text-blue-400 transition"
                  >Servicios</a
                >
              </li>
              <li>
                <a href="/#nosotros" class="hover:text-blue-400 transition"
                  >Sobre Nosotros</a
                >
              </li>
              <li>
                <a href="/#sectores" class="hover:text-blue-400 transition"
                  >Sectores</a
                >
              </li>
              <li>
                <a
                  href="/formulario-rentas"
                  class="text-blue-400 hover:text-blue-300 transition font-bold"
                  >Campaña Renta 2025</a
                >
              </li>
            </ul>
          </div>

          <div class="text-center md:text-left">
            <h4
              class="text-white font-black uppercase text-xs tracking-widest mb-6"
            >
              Legal
            </h4>
            <ul class="space-y-4 text-sm font-medium text-blue-100/60">
              <li>
                <a
                  href="/legal/avisolegal"
                  class="hover:text-blue-400 transition">Aviso Legal</a
                >
              </li>
              <li>
                <a
                  href="/legal/privacidad"
                  class="hover:text-blue-400 transition">Privacidad</a
                >
              </li>
              <li>
                <a href="/legal/cookies" class="hover:text-blue-400 transition"
                  >Cookies</a
                >
              </li>
            </ul>
          </div>

          <div class="text-center md:text-left">
            <h4
              class="text-white font-black uppercase text-xs tracking-widest mb-6"
            >
              Contacto
            </h4>
            <div class="text-sm text-blue-100/60 space-y-4">
              <p
                class="hover:text-blue-300 transition flex items-center justify-center md:justify-start gap-3"
              >
                <span class="bg-blue-500/10 p-2 rounded-lg">📍</span>
                La Laguna, Tenerife
              </p>
              <p
                class="hover:text-blue-300 transition flex items-center justify-center md:justify-start gap-3"
              >
                <span class="bg-blue-500/10 p-2 rounded-lg">📞</span>
                +34 649 73 30 76
              </p>
              <p
                class="hover:text-blue-300 transition flex items-center justify-center md:justify-start gap-3"
              >
                <span class="bg-blue-500/10 p-2 rounded-lg">✉️</span>
                info@canariasnova.com
              </p>
            </div>
          </div>
        </div>

        <div
          class="w-full h-32 rounded-2xl overflow-hidden grayscale opacity-30 hover:opacity-100 transition-all duration-700 border border-white/5 mb-8"
        >
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3507.53202365819!2d-16.3113931247175!3d28.46352027575746!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xc41cd5ddbdeb109%3A0x4882143824126fa6!2sCanarias%20Nova%20Consulting%20SL!5e0!3m2!1ses!2ses!4v1775046321151!5m2!1ses!2ses"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>

        <div class="pt-8 border-t border-white/5 text-center">
          <p
            class="text-blue-300/20 text-[10px] font-bold uppercase tracking-[0.3em]"
          >
            © 2026 Canarias Nova Consulting. Todos los derechos reservados.
          </p>
        </div>
      </div>
    </footer>

    <script>
      // 1. FUNCIÓN PARA LIMPIAR LA URL (Evita que quede rastro de #)
      function limpiarURL() {
        const path = window.location.pathname;
        if (!path.includes("formulario")) {
          // Reemplaza la URL actual por la misma URL pero sin el fragmento #
          window.history.replaceState(
            null,
            "",
            window.location.pathname + window.location.search,
          );
        }
      }

      // Ejecutar al cargar la página por si entran con un link directo tipo web.com/#7
      window.addEventListener("load", limpiarURL);

      // 2. LÓGICA DEL MENÚ MÓVIL (Tu código)
      const btn = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const icon = document.getElementById("menu-icon");
      const mobileLinks = document.querySelectorAll(".mobile-link");

      function toggleMenu() {
        if (!menu || !icon) return;
        const isOpen = menu.classList.contains("opacity-100");
        if (isOpen) {
          menu.classList.replace("scale-y-100", "scale-y-0");
          menu.classList.replace("opacity-100", "opacity-0");
          menu.classList.replace("pointer-events-auto", "pointer-events-none");
          icon.style.transform = "rotate(0deg)";
        } else {
          menu.classList.replace("scale-y-0", "scale-y-100");
          menu.classList.replace("opacity-0", "opacity-100");
          menu.classList.replace("pointer-events-none", "pointer-events-auto");
          icon.style.transform = "rotate(90deg)";
        }
      }

      btn?.addEventListener("click", toggleMenu);

      // 3. MANEJADOR DE CLICS ESTRÍCTO (Para evitar el # en el Nav)
      document.addEventListener("click", (e) => {
        const link = e.target.closest("a");
        if (!link) return;

        const href = link.getAttribute("href");

        // Si el enlace es un ancla (empieza por # o por /#)
        if (
          href &&
          (href.startsWith("#") ||
            (href.startsWith("/#") && window.location.pathname === "/"))
        ) {
          const id = href.startsWith("/#") ? href.substring(1) : href;
          const targetElement = document.querySelector(id);

          if (targetElement) {
            // DETENEMOS EL COMPORTAMIENTO POR DEFECTO (Esto evita que el # suba a la URL)
            e.preventDefault();

            // Cerramos menú móvil si está abierto
            if (menu?.classList.contains("opacity-100")) toggleMenu();

            // Scroll suave manual
            const offset = 100;
            const elementPosition = targetElement.getBoundingClientRect().top;
            const offsetPosition = elementPosition + window.scrollY - offset;

            window.scrollTo({
              top: offsetPosition,
              behavior: "smooth",
            });

            // IMPORTANTE: No usamos window.location.hash ni pushState con el ID.
            // Así la URL se mantiene limpia en la landing.
            if (window.location.pathname.includes("formulario")) {
              // Solo en formulario permitimos el hash si quieres que sea rastreable
              window.history.replaceState(null, "", id);
            } else {
              // En la landing, forzamos que la URL se quede como está
              window.history.replaceState(null, "", window.location.pathname);
            }
          }
        }
      });
    </script>
  </body>
</html>
