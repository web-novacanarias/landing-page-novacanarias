---
import '../styles/global.css'
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Nova Consulting" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 antialiased min-h-screen flex items-center justify-center font-sans">
		<slot />
	</body>
</html>