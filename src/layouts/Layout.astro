---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Consultoría estratégica especializada en Canarias. Soluciones para empresas y profesionales." } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/avif" href="/nova-logo.avif" /> <link rel="canonical" href="https://canariasnova.com" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://canariasnova.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/nova-og-image.jpg" /> </head>
  <body class="bg-[#00236a] text-white font-sans antialiased overflow-x-hidden">
    <nav class="fixed top-4 inset-x-0 z-100 flex justify-center px-4">
      </nav>

    <main class="pt-24 md:pt-32">
      <slot />
    </main>

    <script>
      // Lógica Menú Móvil Mejorada
      const btn = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const icon = document.getElementById("menu-icon");
      const mobileLinks = document.querySelectorAll(".mobile-link");

      function toggleMenu() {
        if (!menu || !icon) return;
        const isOpen = menu.classList.contains("opacity-100");
        
        if (isOpen) {
          menu.classList.replace("scale-y-100", "scale-y-0");
          menu.classList.replace("opacity-100", "opacity-0");
          menu.classList.replace("pointer-events-auto", "pointer-events-none");
          icon.style.transform = "rotate(0deg)";
        } else {
          menu.classList.replace("scale-y-0", "scale-y-100");
          menu.classList.replace("opacity-0", "opacity-100");
          menu.classList.replace("pointer-events-none", "pointer-events-auto");
          icon.style.transform = "rotate(90deg)";
        }
      }

      btn?.addEventListener("click", toggleMenu);
      
      // Cerrar menú al hacer click en un enlace
      mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
          if (menu?.classList.contains("opacity-100")) toggleMenu();
        });
      });

      // SCROLL SUAVE Y LIMPIEZA DE URL
      document.addEventListener("click", (e) => {
        const link = (e.target as HTMLElement).closest("a");
        if (!link) return;

        const href = link.getAttribute("href");
        // Solo actuar si es un ancla interna y estamos en la home
        if (href?.startsWith("#") && href.length > 1) {
          const targetElement = document.querySelector(href);
          if (targetElement) {
            e.preventDefault();
            const offset = 100;
            const elementPosition = targetElement.getBoundingClientRect().top;
            const offsetPosition = elementPosition + window.scrollY - offset;

            window.scrollTo({ top: offsetPosition, behavior: "smooth" });
            // Limpia la URL para que no quede el #id
            window.history.replaceState(null, "", window.location.pathname);
          }
        }
      });
    </script>
  </body>
</html>