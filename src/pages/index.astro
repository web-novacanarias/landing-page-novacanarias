          class="hidden mt-4 text-sm font-bold animate-fade-in transition-all"
        >
        </p>
      </div>

      <div
        class="mt-8 flex items-center justify-center gap-6 text-[11px] text-slate-400 font-bold uppercase tracking-[0.2em]"
      >
        <span class="flex items-center gap-2 italic">Solo lo esencial</span>
        <span class="opacity-30 text-[#00236a]">|</span>
        <span class="flex items-center gap-2 italic">Sin Spam</span>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById("newsletter-form") as HTMLFormElement;
    const btn = document.getElementById("newsletter-btn") as HTMLButtonElement;
    const btnText = document.getElementById("btn-text");
    const status = document.getElementById("form-message");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      // 1. VALIDACIÓN DEL HONEYPOT (TRAMPA BOTS)
      // Usamos e.currentTarget para obtener el formulario actual
      const target = e.currentTarget as HTMLFormElement;
      const formData = new FormData(target);

      // Obtenemos el campo trampa (asegúrate de que el name coincida en el HTML)
      const honeypot = formData.get("confirm_email_address_newsletter") as
        | string
        | null;

      if (honeypot && honeypot.length > 0) {
        console.warn("Spam detectado en Newsletter. Bloqueando envío.");
        // Limpiamos el formulario y fingimos éxito para que el bot no reintente
        form.reset();
        if (status) {
          status.classList.remove("hidden");
          status.innerHTML = "✨ <b>¡Genial!</b> Revisa tu bandeja de entrada.";
          status.className =
            "mt-4 text-sm font-bold text-green-500 block text-center";
        }
        return;
      }
      if (!btn || !status || !btnText) return;

      btn.disabled = true;
      const originalText = btnText.innerText;
      btnText.innerText = "Suscribiendo...";
      status.classList.add("hidden");

      try {
        const res = await fetch("/api/newsletter", {
          method: "POST",
          body: new FormData(form),
        });

        status.classList.remove("hidden");

        if (res.ok) {
          // MENSAJE ÚNICO DE ÉXITO
          status.innerHTML =
            "✨ <b>¡Genial! </b>Revisa tu bandeja de entrada o carpeta de spam para la bienvenida.";
          status.className =
            "mt-4 text-sm font-bold text-green-500 block text-center animate-pulse";
          form.reset();
        } else {
          throw new Error();
        }
      } catch (err) {
        status.classList.remove("hidden");
        status.innerText = "Error temporal. Inténtalo de nuevo.";
        status.className =
          "mt-4 text-sm font-bold text-red-500 block text-center";
      } finally {
        btn.disabled = false;
        btnText.innerText = originalText;
      }
    });
  </script>

