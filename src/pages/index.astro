---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Nova Consulting | Soluciones definitivas para empresas">
  <div
    id="cta-banner"
    class="flex-col md:flex-row items-center justify-between gap-4 md:gap-0"
    style="display: none; position: fixed; bottom: 15px; left: 50%; transform: translateX(-50%); width: 95%; max-width: 750px; background: #002060; color: white; padding: 12px 20px; border-radius: 24px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); z-index: 1000; border: 2px solid #003399;"
  >
    <div class="flex items-center gap-3 md:gap-4 text-center md:text-left">
      <div class="hidden sm:flex items-center justify-center">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#60a5fa"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
      </div>

      <div>
        <p
          id="banner-title"
          style="margin: 0; font-weight: bold; font-size: 15px; line-height: 1.2;"
        >
        </p>
        <p
          id="banner-subtitle"
          style="margin: 0; font-size: 12px; opacity: 0.9;"
        >
        </p>
      </div>
    </div>

    <a
      href="/formulario-rentas"
      class="active:scale-95 transition-transform w-full md:w-auto text-center"
      style="background: white; color: #002060; padding: 8px 20px; border-radius: 15px; text-decoration: none; font-weight: bold; font-size: 13px; white-space: nowrap; box-shadow: 0 4px 6px rgba(0,0,0,0.1);"
    >
      RELLENAR AHORA
    </a>
  </div>

  <script is:inline>
    function initBanner() {
      const banner = document.getElementById("cta-banner");
      const title = document.getElementById("banner-title");
      const subtitle = document.getElementById("banner-subtitle");
      if (!banner || !title) return;

      const hoy = new Date();
      const anio = hoy.getFullYear();

      // Inyectamos el texto usando secuencias Unicode para evitar la Ñ y las tildes en el código fuente
      // \u00F1 = ñ  |  \u00F3 = ó
      title.textContent = "Campa\u00F1a Renta " + (anio - 1);
      subtitle.textContent = "Cuestionario online ya disponible.";

      // Mostrar solo en temporada (Abril a Junio)
      const fechaInicio = new Date(anio, 3, 1);
      const fechaFin = new Date(anio, 6, 1);

      if (hoy >= fechaInicio && hoy <= fechaFin) {
        banner.style.display = "flex";
      }
    }

    initBanner();
    document.addEventListener("astro:after-swap", initBanner);
  </script>
  <!-- HERO -->
  <section
    id="nova"
    class="relative px-6 pt-10 pb-12 md:pt-16 lg:pt-5 overflow-hidden flex items-start bg-[#00236A]"
  >
    <div
      class="absolute top-0 right-0 w-[50%] h-[50%] bg-blue-600/5 blur-[120px] -z-10"
    >
    </div>

    <div
      class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 lg:items-center w-full"
    >
      <div class="order-2 lg:order-1 text-center lg:text-left space-y-8">
        <div class="space-y-4">
          <p
            class="text-slate-300 font-black text-xs md:text-sm uppercase tracking-[0.3em]"
          >
            Asesoría de empresas en Tenerife
          </p>
          <h1
            class="text-4xl sm:text-5xl md:text-6xl font-black leading-[1.1] tracking-tighter text-[#F7F6F6]"
          >
            Soluciones<span class="text-blue-500"> definitivas</span><br
              class="hidden lg:block"
            />
            para empresas <span class="text-blue-500">exigentes</span>.
          </h1>
          <p
            class="text-lg text-blue-100/80 max-w-sm mx-auto lg:mx-0 font-normal leading-relaxed"
          >
            Impulsamos tu negocio con estrategia fiscal, laboral y mercantil de
            alto nivel, especializada en el Régimen Económico y Fiscal de
            Canarias (REF).
          </p>
        </div>

        <div
          class="flex flex-row flex-nowrap justify-center lg:justify-start lg:pl-24 gap-x-10 md:gap-x-14 py-8 border-y border-[#F7F6F6]/10 overflow-x-auto no-scrollbar relative z-10"
        >
          <div class="flex flex-wrap justify-center gap-8 md:gap-12">
            <div class="flex flex-col items-center gap-3 group min-w-22.5">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-12 h-12 text-blue-500 transition-transform group-hover:scale-110"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="4" y="2" width="16" height="20" rx="2"></rect>
                <line x1="8" y1="6" x2="16" y2="6"></line>
                <line x1="16" y1="14" x2="16" y2="14.01"></line>
                <line x1="16" y1="18" x2="16" y2="18.01"></line>
                <line x1="12" y1="10" x2="12" y2="10.01"></line>
                <line x1="12" y1="14" x2="12" y2="14.01"></line>
                <line x1="12" y1="18" x2="12" y2="18.01"></line>
                <line x1="8" y1="10" x2="8" y2="10.01"></line>
                <line x1="8" y1="14" x2="8" y2="14.01"></line>
                <line x1="8" y1="18" x2="8" y2="18.01"></line>
              </svg>
              <span
                class="text-[11px] md:text-xs font-black text-blue-500 uppercase tracking-[0.2em] text-center"
                >Contable</span
              >
            </div>

            <div class="flex flex-col items-center gap-3 group min-w-22.5">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-12 h-12 text-blue-500 transition-transform group-hover:scale-110"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="18" y1="20" x2="18" y2="10"></line>
                <line x1="12" y1="20" x2="12" y2="4"></line>
                <line x1="6" y1="20" x2="6" y2="14"></line>
              </svg>
              <span
                class="text-[11px] md:text-xs font-black text-blue-500 uppercase tracking-[0.2em] text-center"
                >Fiscal</span
              >
            </div>

            <div class="flex flex-col items-center gap-3 group min-w-22.5">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="w-12 h-12 text-blue-500 transition-transform group-hover:scale-110"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              <span
                class="text-[11px] md:text-xs font-black text-blue-500 uppercase tracking-[0.2em] text-center"
                >Laboral</span
              >
            </div>
          </div>
        </div>

        <div
          class="flex flex-col sm:flex-row gap-4 pt-4 lg:hidden relative z-10"
        >
          <a
            href="#contacto"
            class="bg-[#F7F6F6] text-[#00236a] px-10 py-4.5 rounded-2xl font-black text-center uppercase tracking-tighter shadow-xl text-sm active:scale-95 transition-transform"
          >
            Quiero contactar
          </a>
          <a
            href="#servicios"
            class="bg-blue-900/30 text-[#F7F6F6] border border-[#F7F6F6]/10 px-10 py-4.5 rounded-2xl font-black text-center uppercase tracking-tighter text-sm"
          >
            Saber más
          </a>
        </div>
      </div>

      <div
        class="order-1 lg:order-2 flex flex-col items-center justify-center gap-10 w-full relative"
      >
        <div class="relative w-full max-w-4xl group">
          <div
            class="absolute -inset-4 bg-blue-500/10 rounded-[3rem] blur-3xl opacity-60 group-hover:opacity-100 transition duration-1000"
          >
          </div>

          <div
            class="relative w-full aspect-video overflow-hidden rounded-4xl lg:rounded-[3rem] border border-[#F7F6F6]/10 shadow-2xl transition-all duration-500"
          >
            <img
              src="/images/hero-photo.jpg?q=80&w=1200&auto=format&fit=crop"
              alt="Oficinas Nova Consulting"
              class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-1000 scale-105 group-hover:scale-100"
            />
            <div
              class="absolute inset-0 bg-linear-to-t from-[#00236a]/40 via-transparent to-transparent"
            >
            </div>
          </div>
        </div>

        <div
          class="hidden lg:flex flex-row gap-5 w-full justify-center relative z-10"
        >
          <a
            href="#contacto"
            class="flex-1 max-w-xs bg-[#F7F6F6] text-[#00236a] px-8 py-4.5 rounded-2xl font-black text-center uppercase tracking-tighter hover:bg-blue-50 transition shadow-xl text-sm active:scale-95"
          >
            Quiero contactar
          </a>
          <a
            href="#servicios"
            class="flex-1 max-w-xs bg-blue-900/30 text-[#F7F6F6] border border-[#F7F6F6]/10 px-8 py-4.5 rounded-2xl font-black text-center uppercase tracking-tighter hover:bg-blue-900 transition text-sm active:scale-95"
          >
            Saber más
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DESTACABLE -->
  <section
    id="destacable"
    class="py-20 mt-5 bg-[#001a4d] border-y border-[#F7F6F6]/5"
  >
    <div
      class="max-w-7xl mx-auto px-6 flex flex-wrap justify-center gap-16 md:gap-32 text-center"
    >
      <div class="flex flex-col items-center group">
        <div
          class="mb-4 text-[#F7F6F6] group-hover:scale-110 transition-transform duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-10 h-10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>
        <p class="text-6xl font-black text-brand-secondary">
          <span class="text-blue-500">+</span>15
        </p>
        <p
          class="text-xs font-bold uppercase text-slate-300 tracking-widest mt-2"
        >
          Años de experiencia, a tu servicio
        </p>
      </div>

      <div class="flex flex-col items-center group">
        <div
          class="mb-4 text-[#F7F6F6] group-hover:scale-110 transition-transform duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-10 h-10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"
            ></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <p class="text-6xl font-black text-brand-secondary">
          100<span class="text-blue-500">%</span>
        </p>
        <p
          class="text-xs font-bold uppercase text-slate-300 tracking-widest mt-2"
        >
          Origen Canario, de aquí, para aquí
        </p>
      </div>

      <div class="flex flex-col items-center group">
        <div
          class="mb-4 text-[#F7F6F6] group-hover:scale-110 transition-transform duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-10 h-10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
            ></path>
            <path
              d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
            ></path>
            <path d="M9 12H4s.55-3.03 2-5c1.62-2.2 5-3 5-3"></path>
            <path d="M12 15v5s3.03-.55 5-2c2.2-1.62 3-5 3-5"></path>
          </svg>
        </div>
        <p class="text-6xl font-black text-brand-secondary">
          TOP<span class="text-blue-500">↑</span>
        </p>
        <p
          class="text-xs font-bold uppercase text-slate-300 tracking-widest mt-2"
        >
          Tu crecimiento, nuestra prioridad
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios" class="py-24 bg-[#F7F6F6] overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-20">
        <div>
          <h2
            class="text-5xl md:text-6xl font-black text-[#00236a] underline decoration-blue-500/30 tracking-tighter"
          >
            ¿Qué servicios <br /> ofrecemos?
          </h2>
        </div>
        <div class="border-l-2 border-blue-500/30 pl-8">
          <p
            class="text-lg md:text-xl text-[#00236a]/80 font-medium leading-relaxed max-w-2xl"
          >
            En nuestra asesoría ayudamos a <span
              class="underline text-[#00236a]">autónomos y empresas</span
            > a centrarse en lo que realmente importa: <span
              class="text-[#00236a] font-bold">hacer crecer su negocio</span
            >.<br />
            Nos encargamos de todo lo demás: fiscalidad, contabilidad, laboral, subvenciones
            y constitución de sociedades. Con un enfoque <span
              class="text-[#00236a] font-bold">claro, cercano y adaptado</span
            >
            a la realidad de todos. Trabajamos contigo para que tomes decisiones con
            <span class="text-[#00236a]">tranquilidad y respaldo</span> profesional.
            Olvídate del papeleo,
            <span class="underline text-[#00236a]">nosotros nos ocupamos</span>.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 perspective-[1000px]">
        {
          [
            {
              title: "Fiscalidad",
              icon: `<rect x="2" y="6" width="20" height="12" rx="2"></rect><circle cx="12" cy="12" r="2"></circle><path d="M6 12h.01M18 12h.01"></path>`,
              frontText:
                "Presentamos tus impuestos a tiempo, sin errores. Optimizamos tu carga fiscal desde el día uno. Cumples con Hacienda sin complicarte la vida.",
              features: [
                "Declaraciones trimestrales y anuales.",
                "Revisión de tus impuestos.",
                "Asesor fiscal asignado para consultas.",
                "Gestión de notificaciones de Hacienda.",
                "Optimizamos para que pagues menos.",
              ],
            },
            {
              title: "Laboral",
              icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>`,
              frontText:
                "Altas, bajas y contratos sin dolores de cabeza. Nóminas claras, bien hechas y a tiempo. Cumplimiento total con la normativa vigente.",
              features: [
                "Gestión de nóminas y seguros sociales.",
                "Contratos adaptados a convenios vigentes.",
                "Alta/baja en Seguridad Social en 24h.",
                "Consultoría laboral para evitar sanciones.",
                "Defensa ante inspecciones laborales.",
              ],
            },
            {
              title: "Contabilidad",
              icon: `<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>`,
              frontText:
                "Llevamos tus libros contables al día, sin líos. Informes claros para que sepas cómo va tu negocio. Olvídate del Excel.",
              features: [
                "Informes mensuales claros y visuales.",
                "Cuadro de mando financiero actualizado.",
                "Herramienta para escaneo automático de facturas.",
                "Control de gastos y previsión de tesoreria.",
                "Cero Excel: todo automatizado.",
              ],
            },
          ].map((s) => (
            <div class="service-card-container h-110 w-full cursor-pointer group">
              <div class="service-card-inner relative w-full h-full transition-transform duration-700 transform-3d">
                <div class="absolute inset-0 backface-hidden bg-white group-hover:bg-[#00236a] p-10 rounded-[3rem] border border-[#00236a]/5 flex flex-col justify-between shadow-xl transition-all duration-500">
                  <div>
                    <div class="mb-8 flex items-center justify-start transition-transform group-hover:scale-110">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-14 h-14 text-[#00236a] group-hover:text-white transition-colors"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={s.icon}
                      />
                    </div>
                    <h3 class="text-4xl font-black text-[#00236a] group-hover:text-white leading-tight mb-4 transition-colors tracking-tighter">
                      {s.title}
                    </h3>
                    <p class="text-slate-600 group-hover:text-blue-100/70 font-medium leading-relaxed transition-colors">
                      {s.frontText}
                    </p>
                  </div>
                  <span class="text-blue-500 group-hover:text-white font-bold tracking-widest uppercase text-[10px] flex items-center gap-2 transition-colors">
                    Detalles+
                  </span>
                </div>

                <div class="absolute inset-0 backface-hidden transform-[rotateY(180deg)] bg-white group-hover:bg-[#00236a] p-10 rounded-[3rem] flex flex-col border-4 border-[#00236a]/5 shadow-2xl transition-all duration-500">
                  <h3 class="text-2xl font-black mb-2 text-[#00236a] group-hover:text-white transition-colors">
                    {s.title}
                  </h3>
                  <div class="h-1 w-10 bg-blue-500 mb-6" />
                  <ul class="space-y-4 grow">
                    {s.features.map((feature) => (
                      <li class="flex items-start gap-4 text-slate-700 group-hover:text-white/90 font-semibold italic text-sm leading-snug transition-colors">
                        <span class="text-blue-500 group-hover:text-blue-300 mt-0.5 transition-colors shrink-0">
                          <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-6 h-6"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <polyline points="20 6 9 17 4 12" />
                          </svg>
                        </span>
                        {feature}
                      </li>
                    ))}
                  </ul>
                  <p class="mt-6 text-[#00236a]/30 group-hover:text-white/20 font-black uppercase text-[9px] tracking-[0.2em] transition-colors text-center">
                    Nova Consulting Tenerife
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <style>
    .flipped {
      transform: rotateY(180deg);
    }
  </style>

  <script>
    function initServiceCards() {
      const containers = document.querySelectorAll(".service-card-container");
      containers.forEach((container) => {
        container.addEventListener("click", () => {
          const inner = container.querySelector(".service-card-inner");
          if (inner) inner.classList.toggle("flipped");
        });
      });
    }
    initServiceCards();
    document.addEventListener("astro:after-swap", initServiceCards);
  </script>

  <!-- NOSOTROS -->
  <section
    id="nosotros"
    class="relative bg-[#00236a] font-sans overflow-hidden"
  >
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div
        class="absolute top-[20%] -right-[10%] w-[40%] h-[40%] bg-blue-500/10 blur-[120px] rounded-full"
      >
      </div>
      <div
        class="absolute bottom-[20%] -left-[10%] w-[40%] h-[40%] bg-blue-600/10 blur-[120px] rounded-full"
      >
      </div>
    </div>

    <div class="max-w-400 mx-auto px-6 lg:px-20 pt-16 lg:pt-32">
      <div class="flex flex-col lg:flex-row gap-0 lg:gap-24">
        <div
          class="w-full lg:w-5/12 lg:sticky lg:top-20 lg:h-fit flex flex-col justify-center pb-2 lg:pb-32"
        >
          <span
            class="inline-block w-fit px-4 py-1.5 mb-6 text-xs font-bold tracking-[0.2em] uppercase text-blue-400 bg-blue-500/10 rounded-full border border-blue-400/20"
          >
            Experiencia Nova
          </span>

          <h2
            class="text-4xl md:text-6xl font-black text-white tracking-tighter leading-[0.95] mb-8"
          >
            Soluciones <span class="italic text-blue-500">progresivas</span>
            <br />
            para negocios <span class="italic text-blue-500">progresivos</span>
            <br />
          </h2>

          <p
            class="text-blue-100/70 text-lg md:text-xl leading-relaxed mb-0 lg:mb-10 max-w-md"
          >
            Acompañamos a negocios que apuestan por el crecimiento<span
              class="font-bold"
            >
              sostenible</span
            >, la transformación <span class="font-bold"> digital</span> y la toma
            de decisiones con <span class="font-bold"> impacto real</span>.
            Nuestro equipo combina <span class="underline"> experiencia</span>, <span
              class="underline">análisis</span
            > y visión de <span class="underline">futuro</span> para ayudarte a avanzar
            con <span class="font-bold">confianza</span>.
          </p>
