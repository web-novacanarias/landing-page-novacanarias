              class="h-4 w-4 group-hover:translate-x-1 transition-transform"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </button>
        </form>

        <p
          id="form-message"
          class="hidden mt-4 text-sm font-bold animate-fade-in transition-all"
        >
        </p>
      </div>

      <div
        class="mt-8 flex items-center justify-center gap-6 text-[11px] text-slate-400 font-bold uppercase tracking-[0.2em]"
      >
        <span class="flex items-center gap-2 italic">Solo lo esencial</span>
        <span class="opacity-30 text-[#00236a]">|</span>
        <span class="flex items-center gap-2 italic">Sin Spam</span>
      </div>
    </div>
  </section>

  <script>
    const form = document.querySelector("#newsletter-form") as HTMLFormElement;
    const formMessage = document.getElementById("form-message");

    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const submitBtn = form.querySelector("button");
      const btnText = document.getElementById("btn-text");

      // Estado de carga
      if (submitBtn && btnText) {
        submitBtn.disabled = true;
        btnText.innerText = "Procesando...";
      }

      // Limpiar mensaje anterior
      if (formMessage) {
        formMessage.classList.add("hidden");
      }

      try {
        const response = await fetch("/api/subscribe", {
          method: "POST",
          body: formData,
        });

        if (formMessage) {
          formMessage.classList.remove("hidden");

          if (response.ok) {
            formMessage.innerText = "¡Te has suscrito con éxito! Bienvenido.";
            formMessage.className =
              "mt-4 text-sm font-bold text-green-600 block";
            form.reset();
          } else {
            formMessage.innerText =
              "Vaya, parece que este email ya está en la lista.";
            formMessage.className =
              "mt-4 text-sm font-bold text-amber-600 block";
          }
        }
      } catch (error) {
        if (formMessage) {
          formMessage.classList.remove("hidden");
          formMessage.innerText =
            "Error de conexión. Inténtalo de nuevo más tarde.";
          formMessage.className = "mt-4 text-sm font-bold text-red-500 block";
        }
      } finally {
        if (submitBtn && btnText) {
          submitBtn.disabled = false;
          btnText.innerText = "Suscribirme";
        }

        // Ocultar el mensaje automáticamente después de 5 segundos
        setTimeout(() => {
          if (formMessage) formMessage.classList.add("hidden");
        }, 5000);
      }
    });
  </script>

  <!-- CONTACTO -->
  <section id="contacto" class="py-32 bg-[#00236a] text-[#F7F6F6]">
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-20 items-center">
      <div
        class="aspect-square bg-[#F7F6F6]/5 border border-[#F7F6F6]/10 rounded-[3rem] overflow-hidden relative"
      >
        <div class="absolute inset-0 bg-blue-900/20 mix-blend-overlay"></div>
        <div
          class="w-full h-full bg-[#001a4d] flex items-center justify-center text-blue-300 italic"
        >
          Foto Contacto
        </div>
      </div>
      <div>
        <h2 class="text-5xl font-black mb-8 leading-tight">
          ¿Hablamos?<br /><span class="text-blue-400 italic"
            >Tu futuro empieza aquí.</span
          >
        </h2>
        <form class="space-y-4">
          <input
            type="text"
            placeholder="Nombre"
            class="w-full p-5 bg-[#F7F6F6]/5 rounded-2xl border border-[#F7F6F6]/10 outline-none focus:ring-2 ring-blue-400 font-medium text-[#F7F6F6] placeholder:text-blue-200/40"
          />
          <input
            type="email"
            placeholder="Email"
            class="w-full p-5 bg-[#F7F6F6]/5 rounded-2xl border border-[#F7F6F6]/10 outline-none focus:ring-2 ring-blue-400 font-medium text-[#F7F6F6] placeholder:text-blue-200/40"
          />
          <textarea
            placeholder="Mensaje"
            rows="4"
            class="w-full p-5 bg-[#F7F6F6]/5 rounded-2xl border border-[#F7F6F6]/10 outline-none focus:ring-2 ring-blue-400 font-medium text-[#F7F6F6] placeholder:text-blue-200/40"
          ></textarea>
          <button
            class="w-full bg-[#F7F6F6] text-[#00236a] py-5 rounded-2xl font-black text-lg shadow-2xl hover:bg-blue-50 transition"
            >Enviar Consulta</button
          >
        </form>
      </div>
    </div>
  </section>
</Layout>
