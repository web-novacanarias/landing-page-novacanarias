            placeholder="Tu mejor email..."
            class="flex-1 px-8 py-4 rounded-2xl bg-white/80 text-[#00236a] outline-none focus:ring-2 ring-blue-500/20 font-semibold placeholder:text-slate-400 transition-all text-sm"
            required
          />
          <div class="hidden" aria-hidden="true">
