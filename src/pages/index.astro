          >
            <span id="btn-text">Suscribirme</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 group-hover:translate-x-1 transition-transform"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="3"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
