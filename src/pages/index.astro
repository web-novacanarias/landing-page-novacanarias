  </section>
  <script>
    const contactForm = document.getElementById(
      "contact-form",
    ) as HTMLFormElement;
    const contactBtn = document.getElementById(
      "contact-btn",
    ) as HTMLButtonElement;
    const contactMsg = document.getElementById("contact-response");

    contactForm?.addEventListener("submit", async (e: SubmitEvent) => {
      e.preventDefault();

      // 1. VALIDACIÓN DEL HONEYPOT
      // Forzamos a que e.currentTarget sea tratado como HTMLFormElement
      const target = e.currentTarget as HTMLFormElement;
      const formData = new FormData(target);

      // Obtenemos el valor y le decimos que es un string
      const honeypot = formData.get("confirm_email_address") as string | null;

      // Ahora ya puedes usar .length porque TS sabe que es un string
      if (honeypot && honeypot.length > 0) {
        console.warn("Bot detectado, deteniendo envío.");
        return;
      }

      // 2. LÓGICA DE ENVÍO NORMAL
      if (!contactBtn || !contactMsg) return;

      contactBtn.disabled = true;
      const originalText = contactBtn.innerText;
      contactBtn.innerText = "Enviando...";
      contactMsg.classList.add("hidden");

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          body: formData, // Enviamos el formData que ya tenemos
        });

        contactMsg.classList.remove("hidden");

        if (res.ok) {
          contactMsg.innerHTML =
            "✅ ¡Mensaje enviado con éxito! Te responderemos pronto.";
          contactMsg.className =
            "text-green-400 font-bold mt-4 block text-center bg-green-900/20 p-4 rounded-xl";
          contactForm.reset();
        } else {
          throw new Error();
        }
      } catch {
        contactMsg.classList.remove("hidden");
        contactMsg.innerHTML =
          "❌ Error al enviar. Por favor, inténtalo más tarde.";
        contactMsg.className =
          "text-red-400 font-bold mt-4 block text-center bg-red-900/20 p-4 rounded-xl";
      } finally {
        contactBtn.disabled = false;
        contactBtn.innerText = originalText;
      }
    });

    // LÓGICA DEL SLIDESHOW AUTOMÁTICO
    const img1 = document.getElementById("slideshow-1");
    const img2 = document.getElementById("slideshow-2");
    let showFirst = true;

    if (img1 && img2) {
      setInterval(() => {
        if (showFirst) {
          img1.classList.replace("opacity-100", "opacity-0");
          img2.classList.replace("opacity-0", "opacity-100");
        } else {
          img1.classList.replace("opacity-0", "opacity-100");
          img2.classList.replace("opacity-100", "opacity-0");
        }
        showFirst = !showFirst;
      }, 6000); // Cambia cada 4 segundos
    }
  </script>

