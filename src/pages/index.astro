  <style>
    .card-at-back {
      transform: scale(0.88) translateY(20px) rotate(-2deg);
      z-index: 0;
      opacity: 0.4;
      filter: blur(1px);
    }
    .card-mid-2 {
      transform: scale(0.92) translateY(12px) rotate(1.5deg);
      z-index: 10;
      opacity: 0.7;
    }
    .card-mid-1 {
      transform: scale(0.96) translateY(6px) rotate(-1deg);
      z-index: 20;
      opacity: 0.9;
    }
    .card-front {
      transform: scale(1) translateY(0) rotate(0deg);
      z-index: 30;
      opacity: 1;
    }
    .card-exit {
      transform: translateX(-130%) rotate(-15deg) !important;
      opacity: 0 !important;
      transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    }
  </style>

  <script>
    function setupStack() {
      const stack = document.getElementById("stack");
      if (!stack) return;
      let cards = Array.from(stack.querySelectorAll(".card"));
      function updateStack() {
        cards.forEach((card, i) => {
          card.classList.remove(
            "card-front",
            "card-mid-1",
            "card-mid-2",
            "card-at-back",
            "card-exit",
          );
          if (i === cards.length - 1) card.classList.add("card-front");
          else if (i === cards.length - 2) card.classList.add("card-mid-1");
          else if (i === cards.length - 3) card.classList.add("card-mid-2");
          else card.classList.add("card-at-back");
        });
      }
      stack.addEventListener("click", () => {
        const topCard = cards[cards.length - 1];
        if (!topCard) return;
        topCard.classList.add("card-exit");
        setTimeout(() => {
          const movedCard = cards.pop();
          if (movedCard) {
            cards.unshift(movedCard);
            updateStack();
          }
        }, 500);
      });
      updateStack();
    }
    document.addEventListener("DOMContentLoaded", setupStack);
  </script>

