---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nova Consulting | Próximamente">
	<main class="text-center p-8">
		<div class="space-y-4">
			<span class="inline-block px-3 py-1 text-xs font-semibold tracking-wider text-blue-600 uppercase bg-blue-100 rounded-full">
				En desarrollo
			</span>
			
			<h1 class="text-6xl md:text-8xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-blue-700 to-indigo-600">
				Nova
			</h1>
			
			<p class="text-slate-500 font-medium text-lg md:text-xl">
				Consulting & Gestión
			</p>
		</div>
	</main>
</Layout>