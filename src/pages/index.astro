---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Nova Consulting | Soluciones definitivas para empresas">
  <!-- HERO -->
  <section
    id="nova"
    class="relative px-6 pt-4 md:pt-1 overflow-hidden min-h-[85vh] flex items-center"
  >
    <div
      class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16 items-center"
    >
      <div
        class="order-2 lg:order-1 text-center lg:text-left space-y-8 lg:col-span-1"
      >
        <div class="space-y-4">
          <p
            class="text-slate-300 font-black text-xs md:text-sm uppercase tracking-[0.3em]"
          >
            Asesoría de empresas en Tenerife
          </p>
          <h1
            class="text-4xl sm:text-5xl md:text-6xl font-black leading-[1.1] tracking-tighter text-[#F7F6F6]"
          >
            Soluciones <br class="hidden lg:block" />
            <span class="text-blue-500">definitivas</span><br
              class="hidden lg:block"
            />
            para empresas.
          </h1>
          <p
            class="text-lg text-blue-100/70 max-w-sm mx-auto lg:mx-0 font-normal leading-relaxed"
          >
            Impulsamos tu negocio con estrategia legal y fiscal de alto nivel.
            Especialistas en el marco tributario canario.
          </p>
        </div>

        <div
          class="flex flex-row flex-nowrap justify-between lg:justify-start gap-x-6 md:gap-x-12 py-8 border-y border-[#F7F6F6]/10 overflow-x-auto no-scrollbar"
        >
          <div class="flex flex-col items-center gap-2.5 group min-w-[70px]">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-9 h-9 text-blue-500 transition-transform group-hover:scale-110"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="6" width="20" height="12" rx="2"></rect>
              <circle cx="12" cy="12" r="2"></circle>
              <path d="M6 12h.01M18 12h.01"></path>
            </svg>
            <span
              class="text-[11px] md:text-xs font-black text-blue-500 uppercase tracking-[0.2em] text-center"
              >Fiscal</span
            >
          </div>

          <div class="flex flex-col items-center gap-2.5 group min-w-[70px]">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-9 h-9 text-blue-500 transition-transform group-hover:scale-110"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
            </svg>
            <span
              class="text-[11px] md:text-xs font-black text-blue-500 uppercase tracking-[0.2em] text-center"
              >Laboral</span
            >
          </div>

          <div class="flex flex-col items-center gap-2.5 group min-w-[70px]">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-9 h-9 text-blue-500 transition-transform group-hover:scale-110"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path
                d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"
              ></path>
            </svg>
            <span
              class="text-[11px] md:text-xs font-black text-blue-500 uppercase tracking-[0.2em] text-center"
              >Contable</span
            >
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 pt-4 lg:hidden">
          <a
            href="#contacto"
            class="bg-[#F7F6F6] text-[#00236a] px-10 py-4.5 rounded-2xl font-black text-center uppercase tracking-tighter shadow-xl text-sm"
          >
            Quiero contactar
          </a>
          <a
            href="#servicios"
            class="bg-blue-900/30 text-[#F7F6F6] border border-[#F7F6F6]/10 px-10 py-4.5 rounded-2xl font-black text-center uppercase tracking-tighter text-sm"
          >
            Saber más
          </a>
        </div>
      </div>

      <div
        class="order-1 lg:order-2 lg:col-span-2 flex flex-col items-center justify-center gap-8"
      >
        <div class="relative w-full max-w-3xl group">
          <div class="absolute -inset-4 bg-blue-500/10 rounded-[3rem] blur-3xl">
          </div>

          <div
            class="relative w-full aspect-video overflow-hidden rounded-4xl lg:rounded-[3.5rem] border border-[#F7F6F6]/10 shadow-2xl transition-all duration-500"
          >
            <img
              src="https://images.unsplash.com/photo-1553877522-43269d4ea984?q=80&w=1170&auto=format&fit=crop"
              alt="Oficinas Nova Consulting"
              class="w-full h-full object-cover grayscale-[0.2] hover:grayscale-0 transition-all duration-700"
            />
            <div
              class="absolute inset-0 bg-linear-to-t from-[#00236a]/40 via-transparent to-transparent"
            >
            </div>
          </div>
        </div>

        <div
          class="hidden lg:flex flex-row gap-4 w-full max-w-3xl justify-center"
        >
          <a
            href="#contacto"
            class="flex-1 bg-[#F7F6F6] text-[#00236a] px-8 py-4.5 rounded-2xl font-black text-center uppercase tracking-tighter hover:bg-blue-50 transition shadow-xl text-sm"
          >
            Quiero contactar
          </a>
          <a
            href="#servicios"
            class="flex-1 bg-blue-900/30 text-[#F7F6F6] border border-[#F7F6F6]/10 px-8 py-4.5 rounded-2xl font-black text-center uppercase tracking-tighter hover:bg-blue-900 transition text-sm"
          >
            Saber más
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DESTACABLE -->
  <section
    id="destacable"
    class="py-25 mt-5 bg-[#001a4d] border-y border-[#F7F6F6]/5"
  >
    <div
      class="max-w-7xl mx-auto px-6 flex flex-wrap justify-center gap-16 md:gap-32 text-center"
    >
      <div class="flex flex-col items-center group">
        <div
          class="mb-4 text-[#F7F6F6] group-hover:scale-110 transition-transform duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-10 h-10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
        </div>
        <p class="text-6xl font-black text-brand-secondary">
          <span class="text-blue-500">+</span>27
        </p>
        <p
          class="text-xs font-bold uppercase text-slate-300 tracking-widest mt-2"
        >
          Años de experiencia, a tu servicio
        </p>
      </div>

      <div class="flex flex-col items-center group">
        <div
          class="mb-4 text-[#F7F6F6] group-hover:scale-110 transition-transform duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-10 h-10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"
            ></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
        </div>
        <p class="text-6xl font-black text-brand-secondary">
          100<span class="text-blue-500">%</span>
        </p>
        <p
          class="text-xs font-bold uppercase text-slate-300 tracking-widest mt-2"
        >
          Origen Canario, de aquí, para aquí
        </p>
      </div>

      <div class="flex flex-col items-center group">
        <div
          class="mb-4 text-[#F7F6F6] group-hover:scale-110 transition-transform duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-10 h-10"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"
            ></path>
            <path
              d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"
            ></path>
            <path d="M9 12H4s.55-3.03 2-5c1.62-2.2 5-3 5-3"></path>
            <path d="M12 15v5s3.03-.55 5-2c2.2-1.62 3-5 3-5"></path>
          </svg>
        </div>
        <p class="text-6xl font-black text-brand-secondary">
          TOP<span class="text-blue-500">↑</span>
        </p>
        <p
          class="text-xs font-bold uppercase text-slate-300 tracking-widest mt-2"
        >
          Tu crecimiento, nuestra prioridad
        </p>
      </div>
    </div>
  </section>

</Layout>
