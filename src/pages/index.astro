  <script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
      const banner = document.getElementById("cta-banner");

      // CONFIGURACIÓN DE FECHAS
      // Meses en JS: 0=Ene, 1=Feb, 2=Mar, 3=Abr, 4=May, 5=Jun, 6=Jul...
      const fechaInicio = new Date(2026, 3, 4); // 1 de Abril 2026
      const fechaFin = new Date(2026, 6, 1); // 1 de Julio 2026
      const hoy = new Date();

      if (hoy >= fechaInicio && hoy <= fechaFin) {
        if (banner) {
          banner.style.display = "flex";

          // Animación de entrada
          banner.animate(
            [
              { transform: "translate(-50%, 100%)", opacity: 0 },
              { transform: "translate(-50%, 0)", opacity: 1 },
            ],
            {
              duration: 800,
              easing: "ease-out",
              fill: "forwards",
            },
          );
        }
      }
    });
  </script>
