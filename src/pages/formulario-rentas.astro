---
// src/pages/formulario-renta.astro
import Layout from "../../src/layouts/Layout.astro";
const anioActual = new Date().getFullYear(); // 2026
const ejercicioRenta = anioActual - 1;
---

<Layout title=`Formulario Renta ${ejercicioRenta} - Canarias Nova`>
  <script
    src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"
    is:inline></script>
  <script
    src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"
  ></script>
  <script
    src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"
  ></script>
  <main class="max-w-4xl mx-auto p-6 bg-white shadow-lg my-10 rounded-xl">
    <div
      class="flex justify-between items-center border-b-2 border-blue-900 pb-6 mb-8"
    >
      <img src="/nova-logo.avif" alt="Logo Nova" class="h-16" />
      <div class="text-right">
        <h1 class="text-2xl font-bold text-blue-900">
          CAMPAÑA RENTA {ejercicioRenta}
        </h1>
        <p class="text-sm text-gray-500">Formulario de Toma de Datos</p>
      </div>
    </div>
    <div
      style="background: #f8f9fa; padding: 10px; border-bottom: 1px solid #ddd; display: flex; justify-content: space-between; align-items: center;"
    >
      <span style="font-size: 12px; color: #666;"
        >Borrador guardado automáticamente</span
      >
      <button
        type="button"
        id="reset-form"
        style="background-color: transparent; color: #d9534f; border: 1px solid #d9534f; padding: 5px 12px; border-radius: 4px; cursor: pointer; font-size: 13px; transition: 0.3s;"
      >
        Borrar todo y reiniciar
      </button>
    </div>

    <form id="renta-form">
      <section class="space-y-6">
        <h2
          class="text-xl font-bold bg-blue-900 text-white p-3 rounded-t-lg uppercase tracking-wide"
        >
          1. Datos Personales
        </h2>

        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-6 p-6 border border-gray-200 rounded-b-lg shadow-sm bg-white"
        >
          <div class="md:col-span-2">
            <label class="block text-sm font-bold text-gray-700 mb-1"
              >Nombre y Apellidos *</label
            >
            <input
              type="text"
              name="nombre_apellidos"
              required
              placeholder="Ej: Juan Pérez García"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1"
              >D.N.I. / N.I.E. *</label
            >
            <input
              type="text"
              name="dni_nie"
              id="dni_nie"
              required
              maxlength="10"
              placeholder="12345678X"
              oninput="this.value = this.value.toUpperCase()"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none uppercase"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1"
              >Fecha Vigencia D.N.I. *</label
            >
            <input
              type="date"
              name="fecha_vigencia_dni"
              required
              min="2024-01-01"
              max="2040-12-31"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-bold text-gray-700 mb-1"
              >Dirección Fiscal *</label
            >
            <p class="text-[11px] text-blue-700 mb-1.5 italic font-medium">
              (Residencia habitual a 31-12-{ejercicioRenta})
            </p>
            <input
              type="text"
              name="direccion_fiscal"
              required
              placeholder="Calle, número, CP y Municipio"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1"
              >Ref. Catastral</label
            >
            <input
              type="text"
              name="ref_catastral"
              maxlength="20"
              placeholder="20 dígitos/letras"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none uppercase"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1"
              >Teléfono Móvil *</label
            >
            <input
              type="tel"
              name="telefono"
              required
              pattern="^[67][0-9\s.-]{8,13}$"
              title="Debe empezar por 6 o 7 y tener 9 dígitos"
              placeholder="600000000"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1"
              >E-mail *</label
            >
            <input
              type="email"
              name="email"
              required
              placeholder="correo@ejemplo.com"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div
            class="bg-amber-50 p-4 rounded-lg border border-amber-200 md:col-span-2 shadow-inner"
          >
            <label class="block text-sm font-bold text-amber-900 mb-1"
              >Importe Casilla N.º 505 (Ej. 2024) *</label
            >
            <p class="text-[10px] text-amber-700 mb-2 leading-tight">
              Dato imprescindible para que Nova Consulting obtenga su borrador
              de la AEAT.
            </p>
            <input
              type="text"
              name="casilla_505"
              required
              placeholder="Ej: 450,25"
              class="w-full border-amber-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-amber-500 outline-none font-bold"
            />
          </div>
        </div>
      </section>

      <section class="space-y-6 pt-10">
        <h2
          class="text-xl font-bold bg-blue-900 text-white p-3 rounded-t-lg uppercase tracking-wide"
        >
          2. Circunstancias Familiares
        </h2>

        <div
          class="p-6 border border-gray-200 rounded-b-lg shadow-sm bg-white space-y-6 text-left"
        >
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              Estado Civil: *
            </label>
            <select
              name="estado_civil"
              required
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none cursor-pointer"
            >
              <option value="" disabled selected>Seleccione una opción</option>
              <option value="Soltero/a">Soltero/a</option>
              <option value="Casado/a">Casado/a</option>
              <option value="Divorciado/a">Divorciado/a</option>
              <option value="Separado/a">Separado/a</option>
              <option value="Viudo/a">Viudo/a</option>
              <option value="Pareja de hecho">Pareja de hecho</option>
            </select>
          </div>

          <div class="space-y-4">
            <label class="block text-sm font-bold text-gray-700">
              • N.º de hijos que convivan con usted y que no ganen rentas
              superiores a 8.000 €.
            </label>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div
                class="space-y-2 p-3 border border-gray-100 rounded bg-gray-50"
              >
                <p class="text-xs font-bold text-blue-900">HIJO (1)</p>
                <label class="block text-[11px] text-gray-600"
                  >Fecha Nacimiento (1)</label
                >
                <input
                  type="date"
                  name="hijo1_fecha"
                  class="w-full border-gray-300 rounded border p-1.5 bg-white text-gray-900"
                />
                <label class="block text-[11px] text-gray-600">DNI (1)</label>
                <input
                  type="text"
                  name="hijo1_dni"
                  class="w-full border-gray-300 rounded border p-1.5 bg-white text-gray-900 uppercase"
                />
              </div>

              <div
                class="space-y-2 p-3 border border-gray-100 rounded bg-gray-50"
              >
                <p class="text-xs font-bold text-blue-900">HIJO (2)</p>
                <label class="block text-[11px] text-gray-600"
                  >Fecha Nacimiento (2)</label
                >
                <input
                  type="date"
                  name="hijo2_fecha"
                  class="w-full border-gray-300 rounded border p-1.5 bg-white text-gray-900"
                />
                <label class="block text-[11px] text-gray-600">DNI (2)</label>
                <input
                  type="text"
                  name="hijo2_dni"
                  class="w-full border-gray-300 rounded border p-1.5 bg-white text-gray-900 uppercase"
                />
              </div>

              <div
                class="space-y-2 p-3 border border-gray-100 rounded bg-gray-50"
              >
                <p class="text-xs font-bold text-blue-900">HIJO (3)</p>
                <label class="block text-[11px] text-gray-600"
                  >Fecha Nacimiento (3)</label
                >
                <input
                  type="date"
                  name="hijo3_fecha"
                  class="w-full border-gray-300 rounded border p-1.5 bg-white text-gray-900"
                />
                <label class="block text-[11px] text-gray-600">DNI (3)</label>
                <input
                  type="text"
                  name="hijo3_dni"
                  class="w-full border-gray-300 rounded border p-1.5 bg-white text-gray-900 uppercase"
                />
              </div>
            </div>
          </div>

          <div>
            <label
              class="block text-sm font-bold text-gray-700 mb-1 leading-relaxed"
            >
              • N.º de hijos menores de 25 años que estén actualmente trabajando
              y percepciones salariales totales en el año {ejercicioRenta}
            </label>
            <input
              type="text"
              name="hijos_trabajando"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label
              class="block text-sm font-bold text-gray-700 mb-1 leading-relaxed"
            >
              • Porcentaje (%) Minusvalía tanto del declarante y/o de algún
              miembro de la unidad familiar (Resolución Oficial)
            </label>
            <input
              type="text"
              name="minusvalia_resolucion"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              • Ascendientes a su cargo que convivan con usted
            </label>
            <input
              type="text"
              name="ascendientes_convivencia"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
            <label class="block text-sm font-bold text-gray-700 mb-3">
              • Asignación a Iglesia / Fines sociales: *
            </label>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              <label class="flex items-center gap-2 text-sm text-gray-900">
                <input
                  type="radio"
                  name="asignacion"
                  required
                  value="iglesia"
                  class="w-4 h-4"
                /> Iglesia
              </label>
              <label class="flex items-center gap-2 text-sm text-gray-900">
                <input
                  type="radio"
                  name="asignacion"
                  value="fines_sociales"
                  class="w-4 h-4"
                /> Fines sociales
              </label>
              <label class="flex items-center gap-2 text-sm text-gray-900">
                <input
                  type="radio"
                  name="asignacion"
                  value="ambas"
                  class="w-4 h-4"
                /> Ambas
              </label>
              <label class="flex items-center gap-2 text-sm text-gray-900">
                <input
                  type="radio"
                  name="asignacion"
                  value="ninguna"
                  class="w-4 h-4"
                /> Ninguna
              </label>
            </div>
          </div>

          <div class="pt-2">
            <label
              class="block text-sm font-bold text-gray-700 mb-2 leading-relaxed"
            >
              • ¿Paga pensión alimenticia a sus hijos si estuviera divorciado o
              separado? *
            </label>
            <div class="flex items-center gap-6 mb-3">
              <label class="flex items-center gap-2 text-sm text-gray-900">
                <input
                  required
                  type="radio"
                  name="paga_pension"
                  value="si"
                  class="w-4 h-4"
                /> Sí
              </label>
              <label class="flex items-center gap-2 text-sm text-gray-900">
                <input
                  type="radio"
                  name="paga_pension"
                  value="no"
                  class="w-4 h-4"
                /> No
              </label>
            </div>
            <label class="block text-xs font-bold text-gray-600 mb-1 uppercase"
              >Importe</label
            >
            <input
              type="text"
              name="pension_importe"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>
        </div>
      </section>

      <section class="space-y-6 pt-10">
        <h2
          class="text-xl font-bold bg-blue-900 text-white p-3 rounded-t-lg uppercase tracking-wide"
        >
          3. Rendimientos del Trabajo
        </h2>

        <div
          class="p-6 border border-gray-200 rounded-b-lg shadow-sm bg-white space-y-6 text-left"
        >
          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              • Aportaciones a Sindicatos anual
            </label>
            <input
              type="text"
              name="aportaciones_sindicatos"
              placeholder="0,00€"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              • Gastos de litigio incurridos
            </label>
            <input
              type="text"
              name="gastos_litigio"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              • Cuotas colegios profesionales
            </label>
            <input
              type="text"
              name="cuotas_colegios"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              • ¿Se recibe algún tipo de retribución en especie?
            </label>
            <input
              type="text"
              name="retribucion_especie"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div class="pt-2">
            <label class="block text-sm font-bold text-gray-700 mb-2">
              • ¿Ha existido movilidad geográfica en {ejercicioRenta}? *
            </label>
            <div class="flex items-center gap-6">
              <label
                class="flex items-center gap-2 text-sm text-gray-900 cursor-pointer"
              >
                <input
                  required
                  type="radio"
                  name="movilidad_geografica"
                  value="si"
                  class="w-4 h-4"
                /> Sí
              </label>
              <label
                class="flex items-center gap-2 text-sm text-gray-900 cursor-pointer"
              >
                <input
                  required
                  type="radio"
                  name="movilidad_geografica"
                  value="no"
                  class="w-4 h-4"
                /> No
              </label>
            </div>
          </div>

          <div class="pt-2">
            <label class="block text-sm font-bold text-gray-700 mb-2">
              • ¿Ha estado en situación de ERTE en el ejercicio {
                ejercicioRenta
              }? *
            </label>
            <div class="flex items-center gap-6">
              <label
                class="flex items-center gap-2 text-sm text-gray-900 cursor-pointer"
              >
                <input
                  required
                  type="radio"
                  name="situacion_erte"
                  value="si"
                  class="w-4 h-4"
                /> Sí
              </label>
              <label
                class="flex items-center gap-2 text-sm text-gray-900 cursor-pointer"
              >
                <input
                  required
                  type="radio"
                  name="situacion_erte"
                  value="no"
                  class="w-4 h-4"
                /> No
              </label>
            </div>
          </div>
        </div>
      </section>

      <section class="space-y-6 pt-10">
        <h2
          class="text-xl font-bold bg-blue-900 text-white p-3 rounded-t-lg uppercase tracking-wide"
        >
          4. Rendimientos del Capital Inmobiliario
        </h2>

        <div
          class="p-6 border border-gray-200 rounded-b-lg shadow-sm bg-white space-y-6 text-left"
        >
          <div class="pt-2">
            <label class="block text-sm font-bold text-gray-700 mb-2">
              ¿Posee viviendas de las que obtenga ingresos por alquiler? *
            </label>
            <div class="flex items-center gap-6">
              <label
                class="flex items-center gap-2 text-sm text-gray-900 cursor-pointer"
              >
                <input
                  required
                  type="radio"
                  name="posee_alquileres"
                  value="si"
                  class="w-4 h-4"
                /> Sí
              </label>
              <label
                class="flex items-center gap-2 text-sm text-gray-900 cursor-pointer"
              >
                <input
                  required
                  type="radio"
                  name="posee_alquileres"
                  value="no"
                  class="w-4 h-4"
                /> No
              </label>
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              • Indique cuantas:
            </label>
            <input
              type="number"
              name="cantidad_viviendas_alquiler"
              placeholder="0"
              class="w-full md:w-32 border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              • Rentas percibidas:
            </label>
            <input
              type="text"
              name="rentas_percibidas"
              placeholder="Importe total anual"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>

          <div>
            <label class="block text-sm font-bold text-gray-700 mb-1">
              • Referencias Catastrales:
            </label>
            <textarea
              name="referencias_catastrales_alquiler"
              rows="3"
              placeholder="Indique las referencias de los inmuebles alquilados"
              class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
            ></textarea>
          </div>
        </div>
      </section>

      <section class="space-y-6 pt-6 border-t border-dashed border-gray-200">
        <div class="p-6 bg-white space-y-4 text-left">
          <h3
            class="text-md font-bold text-blue-800 border-b pb-2 mb-4 uppercase"
          >
            Gastos incurridos por el propietario/arrendador
          </h3>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">
                • Impuesto sobre Bienes Inmuebles (IBI):
              </label>
              <input
                type="text"
                name="gasto_ibi"
                placeholder="0,00€"
                class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
              />
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">
                • Tasa de basura:
              </label>
              <input
                type="text"
                name="gasto_basura"
                placeholder="0,00€"
                class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
              />
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">
                • Gastos comunidad:
              </label>
              <input
                type="text"
                name="gasto_comunidad"
                placeholder="Importe total anual"
                class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
              />
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">
                • Gastos de reparación y conservación:
              </label>
              <input
                type="text"
                name="gasto_reparacion"
                placeholder="0,00€"
                class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
              />
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">
                • Seguro de vida asociado al préstamo:
              </label>
              <input
                type="text"
                name="gasto_seguro_vida"
                placeholder="Importe de la prima"
                class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
              />
            </div>

            <div>
              <label class="block text-sm font-bold text-gray-700 mb-1">
                • Seguro de responsabilidad civil:
              </label>
              <input
                type="text"
                name="gasto_seguro_rc"
                placeholder="Importe de la prima"
                class="w-full border-gray-300 rounded-md border p-2.5 bg-white text-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"
              />
            </div>
          </div>
        </div>
      </section>

      <section class="space-y-6 pt-10">
        <h2
          class="text-xl font-bold bg-blue-900 text-white p-3 rounded-t-lg uppercase tracking-wide"
        >
          5. Rendimientos de Actividades Económicas
        </h2>

        <div
          class="p-6 border border-gray-200 rounded-b-lg shadow-sm bg-white space-y-6 text-left"
        >
          <div
            class="space-y-2 text-sm text-gray-700 border-l-4 border-blue-200 pl-4 italic"
          >
            <p>
              • Se necesitan todos los ingresos obtenidos en el año {
                ejercicioRenta
              }.
            </p>
            <p>
              • Se necesitan todos los gastos incurridos en las diferentes
              actividades.
            </p>
            <p>
              • Además, se necesitan las inversiones efectuadas en el año fiscal
              en el negocio.
            </p>
          </div>

          <div class="pt-2">
            <label class="block text-sm font-bold text-gray-700 mb-2">
              ¿Ha iniciado alguna actividad económica en el año {
                ejercicioRenta - 1
              } o {ejercicioRenta}? *
