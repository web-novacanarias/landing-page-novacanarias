              entidades públicas para poderle prestar el servicio que usted nos
              encomienda y siempre en el ámbito de negocio de nuestra empresa.
              Por último, el interesado, titular de los datos, podrá revocar la
              autorización concedida, así como ejercer de manera gratuita sus
              derechos de acceso, rectificación, cancelación y oposición,
              dirigiéndose A CANARIAS NOVA CONSULTING, S.L. con CIF B70632781,
              por escrito al domicilio sito en CAMINO SAN BARTOLOME DE GENETO,
              190 (12) - 38296 SAN CRISTOBAL DE LA LAGUNA, SANTA CRUZ DE
              TENERIFE.
            </p>
          </div>

          <div class="pt-8">
            <button
              type="submit"
              class="w-full bg-blue-900 hover:bg-blue-800 text-white font-bold py-4 px-6 rounded-xl shadow-lg transform active:scale-95 transition-all text-lg uppercase tracking-widest"
            >
              Generar PDF y Finalizar
            </button>
          </div>
        </div>
      </section>
    </form>

    <div
      id="modal-final"
      style="display:none; position:fixed; z-index:1000; left:0; top:0; width:100%; height:100%; background-color: rgba(0,0,0,0.8); align-items:center; justify-content:center; backdrop-filter: blur(4px);"
    >
      <div
        style="background-color: white; padding: 35px; border-radius: 16px; max-width: 550px; width: 90%; text-align: center; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);"
      >
        <div style="font-size: 50px; margin-bottom: 10px;">📄✅</div>
        <h2
          style="color: #002060; margin-top: 0; font-size: 24px; font-weight: 800;"
        >
          ¡PDF Generado con éxito!
        </h2>
        <p style="font-size: 16px; color: #4b5563; margin-bottom: 20px;">
          Su cuestionario se ha descargado en su dispositivo.
        </p>

        <div
          style="background: #fff3cd; padding: 15px; border-radius: 12px; color: #856404; font-size: 14px; text-align: left; margin-bottom: 25px; border: 1px solid #ffeeba;"
        >
          <strong style="display: block; margin-bottom: 8px; font-size: 15px;"
            >📥 ¿Cómo enviarlo ahora?</strong
          >
          <ol style="margin: 0; padding-left: 20px; line-height: 1.6;">
            <li>
              Localice el archivo <b>"Renta_{ejercicioRenta}..."</b> en su carpeta
              de descargas.
            </li>
            <li>Pulse el botón azul de abajo para abrir su correo.</li>
            <li>
              <b>Adjunte el archivo manualmente</b> al email antes de enviarlo.
            </li>
          </ol>
        </div>

        <hr style="border: 0; border-top: 1px solid #edf2f7; margin: 20px 0;" />

        <div style="margin-bottom: 25px;">
          <p
            style="font-weight: bold; color: #b91c1c; margin-bottom: 5px; font-size: 14px;"
          >
            ⚠️ IMPORTANTE (Nuevos clientes):
          </p>
          <p style="font-size: 13px; color: #6b7280; margin-bottom: 12px;">
            Si es la primera vez que trabaja con nosotros, consulte la
            documentación necesaria para adjuntarla también:
          </p>
          <a
            href="/pdf/documentacion/documentacion_necesaria.pdf"
            target="_blank"
            style="display: inline-flex; align-items: center; color: #002060; text-decoration: none; font-size: 14px; font-weight: 600; background: #f0f4f8; padding: 8px 16px; border-radius: 8px;"
          >
            📁 Ver Lista de Documentación
          </a>
        </div>

        <div style="display: flex; flex-direction: column; gap: 12px;">
          <a
            id="btn-enviar-mail"
            href="#"
            style="background-color: #002060; color: white; padding: 16px; border-radius: 12px; text-decoration: none; font-weight: bold; font-size: 16px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);"
          >
            📧 REDACTAR EMAIL AHORA
          </a>

          <button
            onclick="document.getElementById('modal-final').style.display='none'"
            style="background-color: white; color: #6b7280; border: 1px solid #e5e7eb; padding: 10px; cursor: pointer; border-radius: 12px; font-size: 14px; font-weight: 500;"
          >
            Cerrar ventana
          </button>
        </div>
      </div>
    </div>
  </main>

  <script>
    import SignaturePad from "signature_pad";
    const LOGO_BASE64 =
      "data:image/jpeg;base64,";

    const storageKey = "renta_2025_draft";

    document.addEventListener("DOMContentLoaded", () => {
      const form = document.getElementById("renta-form") as HTMLFormElement;
      const canvas = document.getElementById(
        "signature-pad",
      ) as HTMLCanvasElement;
      const clearButton =
        document.getElementById("clear") ||
        document.getElementById("clear-signature");
      const resetButton = document.getElementById("reset-form");
      const fechaInput = document.getElementById(
        "fecha-auto",
      ) as HTMLInputElement;

      if (!form || !canvas) return;

      // --- 1. FIRMA ---
      const signaturePad = new SignaturePad(canvas, {
        backgroundColor: "rgb(255, 255, 255)",
        penColor: "rgb(0, 0, 0)",
      });

      const resizeCanvas = () => {
        const ratio = Math.max(window.devicePixelRatio || 1, 1);
        canvas.width = canvas.offsetWidth * ratio;
        canvas.height = canvas.offsetHeight * ratio;
        canvas.getContext("2d")?.scale(ratio, ratio);
        signaturePad.clear();
      };
      window.addEventListener("resize", resizeCanvas);
      resizeCanvas();

      clearButton?.addEventListener("click", (e) => {
        e.preventDefault();
        signaturePad.clear();
      });

      resetButton?.addEventListener("click", (e) => {
        e.preventDefault(); // Evitamos comportamientos extraños

        if (
          confirm(
            "¿Estás seguro de que quieres borrar todos los datos del formulario?",
          )
        ) {
          // 1. Limpiar el formulario visualmente
          form.reset();

          // 2. Limpiar la firma
          signaturePad.clear();

          // 3. Borrar el borrador guardado en LocalStorage
          localStorage.removeItem(storageKey);

          // 4. Opcional: Re-poner la fecha automática tras el reset
          if (fechaInput) {
            const hoy = new Date();
            fechaInput.value = `${String(hoy.getDate()).padStart(2, "0")}/${String(hoy.getMonth() + 1).padStart(2, "0")}/2026`;
          }

          // Volver al inicio de la página para que el usuario vea que está limpio
          window.scrollTo({ top: 0, behavior: "smooth" });
        }
      });

      // --- 2. PERSISTENCIA Y FECHA ---
      if (fechaInput) {
        const hoy = new Date();
        fechaInput.value = `${String(hoy.getDate()).padStart(2, "0")}/${String(hoy.getMonth() + 1).padStart(2, "0")}/2026`;
      }

      const cargarBorrador = () => {
        const saved = localStorage.getItem(storageKey);
        if (saved) {
          const data = JSON.parse(saved);
          Object.keys(data).forEach((key) => {
            const input = form.elements.namedItem(key) as any;
            if (input) {
              if (input.type === "checkbox") input.checked = !!data[key];
              else if (input.type === "radio") {
                if (input.value === data[key]) input.checked = true;
              } else input.value = data[key];
            }
          });
        }
      };
      cargarBorrador();

      form.addEventListener("input", () => {
        const data = Object.fromEntries(new FormData(form).entries());
        form
          .querySelectorAll('input[type="checkbox"]')
          .forEach((cb: any) => (data[cb.name] = cb.checked));
        localStorage.setItem(storageKey, JSON.stringify(data));
      });

      // --- 3. GENERAR PDF ---
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        // --- 0. CÁLCULO DE FECHAS DINÁMICAS ---
        const anioActual = new Date().getFullYear();
        const ejercicioRenta = anioActual - 1; // La campaña actual siempre es del año anterior

        if (signaturePad.isEmpty()) {
          return alert("Por favor, firme el documento.");
        }

        // Captura de datos del formulario
        const allData = Object.fromEntries(new FormData(form).entries());

        // Procesar Checkboxes para que en el PDF salga SÍ/NO
        form.querySelectorAll('input[type="checkbox"]').forEach((cb: any) => {
          allData[cb.name] = cb.checked ? "SÍ" : "NO";
        });

        const { jsPDF } = (window as any).jspdf;
        const doc = new jsPDF();
        const azulNova = [0, 32, 96];
        const margenX = 20;
        let y = 50;

        // --- 1. CABECERA DEL PDF ---
        const renderHeader = () => {
          doc.setFillColor(...azulNova);
          doc.rect(0, 0, 210, 35, "F");
          if (LOGO_BASE64) {
            doc.setFillColor(255);
            doc.roundedRect(15, 5, 25, 25, 1, 1, "F");
            doc.addImage(LOGO_BASE64, "PNG", 16, 6, 23, 23);
          }
          doc.setTextColor(255);
          doc.setFont("helvetica", "bold");
          doc.setFontSize(16);
          doc.text(`CUESTIONARIO RENTA ${ejercicioRenta}`, 115, 18, {
            align: "center",
          });
          doc.setFontSize(9);
          doc.text("CANARIAS NOVA CONSULTING", 115, 25, { align: "center" });
        };

        const checkPage = (needed: number) => {
          if (y + needed > 275) {
            doc.addPage();
            renderHeader();
            y = 45;
          }
        };

        renderHeader();

        // --- 2. BUCLE DE CAMPOS RELLENOS ---
        Object.entries(allData).forEach(([key, value]) => {
          // Saltamos campos vacíos, botones o firmas
          if (
            !value ||
            value === "" ||
            value === "NO" ||
            key === "signature" ||
            key.includes("submit") ||
            key === "fecha-auto"
          )
            return;

          const label = key.replace(/_/g, " ").toUpperCase();
          const textLines = doc.splitTextToSize(String(value), 160);
          const boxH = Math.max(12, textLines.length * 5 + 8);

          checkPage(boxH + 15);

          doc.setFontSize(8);
          doc.setTextColor(60);
          doc.setFont("helvetica", "bold");
          doc.text(label, margenX, y);
          y += 3;

          doc.setDrawColor(200);
          doc.setFillColor(245);
          doc.roundedRect(margenX, y, 170, boxH, 1, 1, "FD");
          doc.setTextColor(0);
          doc.setFont("helvetica", "normal");
          doc.setFontSize(10);
          doc.text(textLines, margenX + 5, y + boxH / 2 + 1.5, {
            baseline: "middle",
          });
          y += boxH + 7;
        });

        // --- 3. TEXTO LEGAL Y FIRMA ---
        const textoLegal = `En cumplimiento con el RGPD, necesitamos nos firme este CONSENTIMIENTO, autorizándonos a la inclusión de sus datos de carácter personal en los ficheros de nuestra empresa, comunicándole que están bajo nuestra responsabilidad, así como también nos comprometemos a garantizar la privacidad de los mismos y con la única finalidad de llevar a cabo la gestión necesaria a los únicos efectos de la confección de la renta de las personas físicas, declarando que los datos aportados en este cuestionario tienen respaldo con justificantes a mi nombre y mi D.N.I. Igualmente autoriza la cesión de dichos datos personales a entidades públicas para poderle prestar el servicio que usted nos encomienda y siempre en el ámbito de negocio de nuestra empresa. Por último, el interesado, titular de los datos, podrá revocar la autorización concedida, así como ejercer de manera gratuita sus derechos de acceso, rectificación, cancelación y oposición, dirigiéndose A CANARIAS NOVA CONSULTING, S.L. con CIF B70632781, por escrito al domicilio sito en CAMINO SAN BARTOLOME DE GENETO, 190 (12) - 38296 SAN CRISTOBAL DE LA LAGUNA, SANTA CRUZ DE TENERIFE.`;

        doc.setFontSize(7);
        const legalLines = doc.splitTextToSize(textoLegal, 170);
        const hLegal = legalLines.length * 3.5;
        const hFirma = 35;

        checkPage(hLegal + hFirma + 10);

        y += 5;
        doc.setFontSize(10);
        doc.setFont("helvetica", "bold");
        doc.setTextColor(0);
        doc.text("Firma del declarante:", margenX, y);

        const sigImg = signaturePad.toDataURL("image/png");
        doc.addImage(sigImg, "PNG", margenX, y + 2, 50, 20);

        const fFinal =
          allData["fecha-auto"] || new Date().toLocaleDateString("es-ES");
        doc.text(`Fecha: ${fFinal}`, 140, y + 15);

        y += 28;
        doc.setFontSize(7);
        doc.setTextColor(100);
        doc.setFont("helvetica", "normal");
        doc.text(legalLines, margenX, y);

        // Guardar PDF con nombre dinámico
        const nombreArchivo = `Renta_${ejercicioRenta}_${allData["nombre_apellidos"] || "Cuestionario"}.pdf`;
        doc.save(nombreArchivo);

        // --- 4. MODAL Y CONFIGURACIÓN MAILTO ---
        const modal = document.getElementById("modal-final");
        const btnMail = document.getElementById(
          "btn-enviar-mail",
        ) as HTMLAnchorElement;

        if (modal && btnMail) {
          const emailDestino = "info@canariasnova.com";
          const nombreCliente = allData["nombre_apellidos"] || "Cliente";

          const asunto = encodeURIComponent(
            `Cuestionario Renta ${ejercicioRenta} - ${nombreCliente}`,
          );

          const cuerpo = encodeURIComponent(
            `Hola,\n\nAdjunto env\u00EDo mi cuestionario de renta para el ejercicio ${ejercicioRenta} generado desde la web.\n\n` +
              `Nombre: ${nombreCliente}\n` +
              `DNI: ${allData["dni_nie"] || "---"}\n\n` +
              `Saludos.`,
          );

          btnMail.href = `mailto:${emailDestino}?subject=${asunto}&body=${cuerpo}`;
          modal.style.display = "flex";
        }
      });
    });
  </script>
</Layout>
